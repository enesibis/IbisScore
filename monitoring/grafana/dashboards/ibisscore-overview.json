{
  "title": "IbisScore Overview",
  "uid": "ibisscore-overview",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"ibisscore.*\"}[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=~\"ibisscore.*\"}[1m])) by (le, application)) * 1000",
          "legendFormat": "{{application}} p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",application=~\"ibisscore.*\"}[1m])) by (application)",
          "legendFormat": "{{application}} errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",application=~\"ibisscore.*\"} / 1048576",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Redis Cache Hit Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(cache_gets_total{result=\"hit\"}[5m])) / sum(rate(cache_gets_total[5m])) * 100",
          "legendFormat": "Hit %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "RabbitMQ Messages Published",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "sum(rabbitmq_channel_messages_published_total)",
          "legendFormat": "Published"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "title": "Active WebSocket Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "websocket_sessions_total{application=\"ibisscore-match-service\"}",
          "legendFormat": "Sessions"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "title": "DB Connection Pool (active)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=~\"ibisscore.*\"}",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
